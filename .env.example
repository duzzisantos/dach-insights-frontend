# Base URL of the GermanyDashboard.Api backend (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:5080

# Public origin this app is served from (no trailing slash) — used only to build absolute
# URLs in sitemap.xml/robots.txt. Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
